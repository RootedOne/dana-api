# AI Provider Settings
# Options: "google" or "openai"
AI_PROVIDER=google

# Model Selection
# Example for Google: gemini-2.0-flash-lite-preview-02-05
# Example for OpenAI/Compatible: gpt-4o, llama3, etc.
AI_MODEL=gemini-2.0-flash-lite-preview-02-05

# Your AI API Key
AI_API_KEY=your_key_here

# Base URL for OpenAI-compatible providers (Groq, Ollama, Together.ai, etc.)
# Leave empty by default to use official OpenAI endpoints.
AI_BASE_URL=

# Model Temperature
AI_TEMPERATURE=0.1

# TMDB Settings
# Used for fetching official, high-quality movie posters
TMDB_API_KEY=your_tmdb_api_key_here
